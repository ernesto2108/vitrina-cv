# vitrina-cv — environment variables
# Copy to .env and adjust values for local development.
# All thresholds are read at startup; changing a value only requires a service restart.

# --- CV Engine (ADR-008) ---
# Active engine for geometry extraction. Phase 1 value: "opencv".
# Future value: "rasterscan" (not yet implemented).
CV_ENGINE=opencv

# Path to ML model weights. Optional — unused in Phase 1 (ADR-008).
# Leave empty for OpenCV classic mode.
CV_MODEL_PATH=

# --- Preflight thresholds (ADR-005) ---
# Minimum acceptable image resolution in "WxH" format.
CV_PREFLIGHT_MIN_RESOLUTION=800x600

# Minimum Michelson contrast ratio [0.0 – 1.0].
# Images below this threshold are rejected by the preflight gate.
CV_PREFLIGHT_MIN_CONTRAST=0.35

# Minimum ratio of edge pixels to total pixels [0.0 – 1.0].
# Images below this threshold are considered to have insufficient line density.
CV_PREFLIGHT_MIN_LINE_DENSITY=0.05

# --- Server ---
PORT=8000

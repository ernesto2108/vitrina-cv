# vitrina-cv — environment variables
# Copy to .env and adjust values for local development.
# All thresholds are read at startup; changing a value only requires a service restart.

# --- CV Engine (ADR-008) ---
# Active engine for geometry extraction. Phase 1 value: "opencv".
# Future value: "rasterscan" (not yet implemented).
CV_ENGINE=opencv

# Path to ML model weights. Optional — unused in Phase 1 (ADR-008).
# Leave empty for OpenCV classic mode.
CV_MODEL_PATH=

# --- Preflight thresholds (ADR-005) ---
# Minimum acceptable image resolution in "WxH" format.
# Evaluated on the ORIGINAL image (before upscaling) — this is the
# "non-rescuable" floor: images below this size cannot yield useful geometry
# even after upscaling.  Lowered from 800x600 to 300x300 because upscaling
# now handles small-but-valid floor plans (see CV_UPSCALE_TARGET_PX).
CV_PREFLIGHT_MIN_RESOLUTION=300x300

# Minimum Michelson contrast ratio [0.0 – 1.0].
# Images below this threshold are rejected by the preflight gate.
CV_PREFLIGHT_MIN_CONTRAST=0.35

# Minimum ratio of edge pixels to total pixels [0.0 – 1.0].
# Images below this threshold are considered to have insufficient line density.
CV_PREFLIGHT_MIN_LINE_DENSITY=0.05

# --- Resolution normalisation (upscale) ---
# Long-side target (px) after resolution normalisation.  Images whose long
# side is already >= this value are left unchanged (factor = 1.0).
# The OpenCV engine's absolute-pixel constants are calibrated for ~2000 px images.
CV_UPSCALE_TARGET_PX=2000

# Safety cap on the upscale factor.  Prevents inflating tiny thumbnails or
# icons (e.g. a 100×100 preview) to impractical sizes.
CV_UPSCALE_MAX_FACTOR=4.0

# --- Server ---
PORT=8000
